# --- Core ---
NODE_ENV=development
PORT=3000
# Postgres (Railway provides DATABASE_URL automatically when you add a Postgres plugin)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/slipstitch?schema=public

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# Sign in with Apple
APPLE_CLIENT_ID=com.slipstitch.app          # your app's bundle id / services id (audience)
APPLE_TEAM_ID=XXXXXXXXXX
# (Apple public keys are fetched from https://appleid.apple.com/auth/keys; no secret needed to verify identity tokens)

# --- Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
R2_BUCKET=slipstitch-media
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# Public base URL for serving media (R2 public bucket or Cloudflare CDN domain)
R2_PUBLIC_BASE_URL=https://media.slipstitch.app

# --- Feature flags ---
EXTERNAL_SEARCH_ENABLED=false   # Pinterest/web search integration (off until API access approved)
