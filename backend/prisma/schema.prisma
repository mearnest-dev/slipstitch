// Stitchbook data model — the source of truth for the API contract (docs/API.md).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  planning
  inProgress
  finished
  frogged
}

enum PinSource {
  pinterest
  web
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  passwordHash String?
  appleSub     String?  @unique // Apple "sub" claim
  username     String   @unique
  displayName  String
  bio          String?
  avatarPhoto  Photo?   @relation("UserAvatar", fields: [avatarPhotoId], references: [id])
  avatarPhotoId String? @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects     Project[]
  collections  Collection[]
  photos       Photo[]        @relation("PhotoOwner")
  likes        Like[]
  refreshTokens RefreshToken[]
  following    Follow[]       @relation("Follower")
  followers    Follow[]       @relation("Following")

  @@index([username])
}

model RefreshToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
}

model Project {
  id          String        @id @default(cuid())
  owner       User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String
  title       String
  description String?
  craftType   String?       // e.g. "amigurumi", "blanket", "garment"
  yarn        String?
  hookSize    String?
  status      ProjectStatus @default(planning)
  isPublic    Boolean       @default(false)
  cover       Photo?        @relation("ProjectCover", fields: [coverPhotoId], references: [id])
  coverPhotoId String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  logs        ProgressLog[]
  photos      Photo[]       @relation("ProjectPhotos")
  likes       Like[]
  tags        ProjectTag[]
  collectionItems CollectionItem[]

  @@index([ownerId])
  @@index([isPublic, createdAt])
}

model ProgressLog {
  id         String   @id @default(cuid())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  note       String?
  photo      Photo?   @relation("LogPhoto", fields: [photoId], references: [id])
  photoId    String?
  rowCount   Int?
  hoursSpent Float?
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
}

model Photo {
  id        String   @id @default(cuid())
  owner     User     @relation("PhotoOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String
  r2Key     String   @unique
  width     Int?
  height    Int?
  blurhash  String?
  uploaded  Boolean  @default(false) // flips true after /complete
  createdAt DateTime @default(now())

  // back-relations
  project   Project? @relation("ProjectPhotos", fields: [projectId], references: [id])
  projectId String?
  avatarOf  User?    @relation("UserAvatar")
  coverOf   Project[] @relation("ProjectCover")
  logsOf    ProgressLog[] @relation("LogPhoto")

  @@index([ownerId])
}

model Collection {
  id           String   @id @default(cuid())
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId      String
  name         String
  description  String?
  isPublic     Boolean  @default(false)
  coverPhotoId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        CollectionItem[]

  @@index([ownerId])
}

model CollectionItem {
  id            String      @id @default(cuid())
  collection    Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId  String
  // exactly one of project / externalPin is set
  project       Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String?
  externalPin   ExternalPin? @relation(fields: [externalPinId], references: [id], onDelete: Cascade)
  externalPinId String?
  createdAt     DateTime    @default(now())

  @@unique([collectionId, projectId])
  @@unique([collectionId, externalPinId])
  @@index([collectionId])
}

model ExternalPin {
  id        String    @id @default(cuid())
  source    PinSource
  sourceUrl String    @unique
  imageUrl  String
  title     String?
  createdAt DateTime  @default(now())

  collectionItems CollectionItem[]
}

model Like {
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime @default(now())

  @@id([userId, projectId])
  @@index([projectId])
}

model Follow {
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followerId  String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  followingId String
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followingId])
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  projects ProjectTag[]
}

model ProjectTag {
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String

  @@id([projectId, tagId])
  @@index([tagId])
}
